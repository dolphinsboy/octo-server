# MinIO Configuration
MINIO_ROOT_USER: minio
MINIO_ROOT_PASSWORD: CHANGE_ME_MINIO_PASSWORD
MINIO_SERVER_URL: http://localhost:9000
MINIO_BROWSER_REDIRECT_URL: http://localhost:9001

# MySQL Configuration
MYSQL_ROOT_PASSWORD: CHANGE_ME_MYSQL_PASSWORD
MYSQL_DATABASE: im

# Web Configuration
API_URL=http://octo-server:8090

# OCTO 实名认证链路（YUJ-354 / GH#1300）——
# 与 dmwork-verify-service (accounts.example.com) 共享以下两个 secret。
# 未配置时 /internal/verification/complete 恒回 401、/internal/verify-token 恒回 503（fail-closed）。
# 详见 docs/octo-verification.md。
OCTO_INTERNAL_HMAC_SECRET=CHANGE_ME_HMAC_SHARED_WITH_VERIFY_SERVICE
OCTO_JWT_SECRET=CHANGE_ME_JWT_SHARED_WITH_VERIFY_SERVICE
# 可选：verify-service 跳转基址（默认 https://accounts.example.com/verify）
# OCTO_VERIFY_URL_BASE=https://accounts.example.com/verify
# 可选：前端未传 return_to 时的默认值
# OCTO_VERIFY_RETURN_TO_DEFAULT=https://api.example.com/
